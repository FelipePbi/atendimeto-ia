# Ambiente de execucao da API
NODE_ENV=development

# Porta HTTP do servidor
API_PORT=3000

# Banco da API Node
DATABASE_URL=postgresql://app:app@api-postgres:5432/salao?sslmode=disable
API_POSTGRES_USER=app
API_POSTGRES_PASSWORD=app
API_POSTGRES_DB=salao

# Canal WhatsApp via Evolution Go
CHANNEL_PROVIDER=evolution-go
EVOLUTION_WEBHOOK_TOKEN=troque-este-token
EVOLUTION_BASE_URL=http://evolution-go:8080
EVOLUTION_API_KEY=troque-esta-chave-global
EVOLUTION_INSTANCE_ID=
EVOLUTION_INSTANCE_TOKEN=
EVOLUTION_INSTANCE_NAME=salao-principal
EVOLUTION_SEND_TEXT_PATH=/send/text
EVOLUTION_IGNORE_GROUPS=true
EVOLUTION_BOT_ENABLED=true
HUMAN_HANDOFF_PAUSE_MINUTES=120

# Banco do Evolution Go
EVOGO_POSTGRES_USER=postgres
EVOGO_POSTGRES_PASSWORD=postgres
EVOGO_AUTH_DB=evogo_auth
EVOGO_USERS_DB=evogo_users
EVOGO_DATABASE_SAVE_MESSAGES=false
EVOGO_WADEBUG=INFO
EVOGO_LOGTYPE=console

# Chave da OpenAI
OPENAI_API_KEY=

# Modelo usado pelo atendente
OPENAI_MODEL=gpt-5.4-mini

# Limite de tokens da resposta da IA
OPENAI_MAX_OUTPUT_TOKENS=600

# URL base da API Minha Agenda
MINHA_AGENDA_BASE_URL=https://api.minhaagendaapp.com.br

# Credencial Basic usada no endpoint OAuth do Minha Agenda
MINHA_AGENDA_BASIC_AUTH=

# Email de login do Minha Agenda
MINHA_AGENDA_USERNAME=

# Senha de login do Minha Agenda
MINHA_AGENDA_PASSWORD=

# Profissional padrao que recebe os agendamentos
MINHA_AGENDA_DEFAULT_EMPLOYEE_ID=873242

# Metodo de pagamento padrao confirmado nos contratos reais
MINHA_AGENDA_DEFAULT_PAYMENT_METHOD=CASH

# Versao do modelo exigida no payload de agendamento
MINHA_AGENDA_MODEL_VERSION=2

# Timeout das chamadas ao Minha Agenda
MINHA_AGENDA_TIMEOUT_MS=10000

# Margem para renovar token antes de expirar
MINHA_AGENDA_TOKEN_REFRESH_SKEW_SECONDS=300

# Libera chamadas reais de escrita no Minha Agenda
MINHA_AGENDA_ENABLE_WRITES=false

# Roda testes de integracao read-only contra a API real do Minha Agenda
MINHA_AGENDA_RUN_INTEGRATION_TESTS=false

# Fuso horario do negocio
BUSINESS_TIMEZONE=America/Sao_Paulo

# Quantidade maxima de horarios oferecidos por resposta
BUSINESS_MAX_SLOTS_TO_OFFER=3

# Horizonte de busca de disponibilidade
BUSINESS_AVAILABILITY_DAYS=14

# Granularidade dos slots gerados
BUSINESS_SLOT_STEP_MINUTES=30

# Horizonte para localizar agenda futura da cliente
BUSINESS_APPOINTMENT_LOOKUP_DAYS=90

# Nome do negocio usado no prompt
BUSINESS_NAME=

# Nome da profissional usado no prompt
BUSINESS_PROFESSIONAL_NAME=

# Endereco do atendimento, se a cliente perguntar
BUSINESS_ADDRESS=

# Politica de atraso usada pela IA
BUSINESS_DELAY_POLICY=

# Politica de cancelamento usada pela IA
BUSINESS_CANCELLATION_POLICY=

# Politica de sinal/pagamento antecipado, se existir
BUSINESS_DEPOSIT_POLICY=

# Token simples para endpoints internos/admin
ADMIN_API_TOKEN=
